{
  "name": "gsgw-reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "epub": "node scripts/epub.mjs",
    "serve": "node scripts/build.mjs && npx serve website",
    "watch": "node scripts/watch.mjs",
    "deploy": "wrangler deploy --config worker/wrangler.toml",
    "preview": "wrangler dev --config worker/wrangler.toml",
    "format": "prettier --write \"scripts/**/*.{mjs,js}\" \"assets/js/**/*.js\" \"assets/css/*.css\" \"worker/src/**/*.js\" \"*.json\""
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "wrangler": "^4.99.0"
  },
  "dependencies": {
    "eta": "^4.6.0",
    "pdfjs-dist": "^6.0.227"
  }
}
